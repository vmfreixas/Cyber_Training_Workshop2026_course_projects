  Nactel = 6 0 0
  Inactive = 22
  Ras2 = 4
  CiRoot = 4 4 1
  RlxRoot = 1
  LumOrb
  LevShift = 1.0

&ALASKA

&SLAPAF
  MaxStep = 0.10

>>> EndDo
